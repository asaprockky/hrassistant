# Copy to .env and fill in real values. NEVER commit the real .env.
# The previously hardcoded secrets (JWT key, Gmail app password, DB URL) have
# been removed from the source and MUST be rotated.

# --- Database ---
# Full SQLAlchemy/psycopg2 connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Auth / JWT ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Email (SMTP) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_LOGIN=your-sender@example.com
SMTP_APP_PASSWORD=your-gmail-app-password
SENDER_EMAIL=your-sender@example.com
